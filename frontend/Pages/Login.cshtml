@page
@model SeedHR.Frontend.Pages.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap | SeedHR</title>
    
    <!-- Tailwind and Font setup -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        indigo: {
                            50: '#f2faf6',
                            100: '#e2f5ec',
                            200: '#c5ebda',
                            300: '#9adbc0',
                            400: '#66c49e',
                            500: '#3da87d',
                            600: '#0ba360',
                            700: '#0b804c',
                            800: '#0a663f',
                            900: '#085334',
                            950: '#042e1d',
                        },
                        slate: {
                            50: '#f8faf9',
                            100: '#f0f4f2',
                            200: '#e1e8e4',
                            300: '#cad4cf',
                            400: '#9cb0a6',
                            500: '#738a80',
                            600: '#576b63',
                            700: '#44544d',
                            800: '#33403a',
                            900: '#1b2420',
                            950: '#0d1210',
                        }
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body {
            font-family: 'Outfit', sans-serif;
        }
    </style>
</head>
<body class="flex min-h-screen bg-slate-50 font-sans items-center justify-center p-4 transition-colors">

    <!-- Main card wrapper -->
    <div class="flex w-full max-w-4xl rounded-3xl overflow-hidden shadow-[0_15px_50px_rgba(0,0,0,0.02)] bg-white border border-slate-100">
        
        <!-- Left Side: Illustration / Brand Banner -->
        <div class="hidden md:flex flex-col justify-between w-1/2 bg-gradient-to-br from-indigo-50/60 via-indigo-100/40 to-indigo-200/10 p-10 text-left border-r border-slate-100">
            <div class="flex items-center gap-2">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-600 font-bold text-white shrink-0">
                    S
                </div>
                <span class="font-semibold text-base text-slate-800 tracking-wide">
                    Seed<span>HR</span>
                </span>
            </div>

            <div class="space-y-4 my-auto">
                <h2 class="text-2xl font-bold leading-snug text-slate-800">
                    Kurumsal İnsan Kaynakları Yönetim Sistemi
                </h2>
                <p class="text-xs text-slate-500 leading-relaxed font-medium">
                    SeedHR; çalışan özlük hakları, izin yönetimi, günlük mesai kaydı, dönemsel performans değerlendirmeleri ve işe alım süreçlerini tek bir çatı altında toplayan uçtan uca kurumsal bir platformdur.
                </p>
            </div>

            <div class="text-[10px] text-slate-400 font-medium">
                © 2026 SeedHR Inc. Tüm hakları saklıdır.
            </div>
        </div>

        <!-- Right Side: Form -->
        <div class="w-full md:w-1/2 p-8 sm:p-10 flex flex-col justify-center bg-white">
            <div class="text-left mb-6">
                <h1 class="text-xl font-bold text-slate-800">Sisteme Giriş Yapın</h1>
                <p class="text-xs text-slate-400 mt-1">Devam etmek için kurumsal hesabınızı kullanın.</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mb-5 p-4 rounded-xl bg-rose-50 border border-rose-100 text-rose-600 text-xs flex items-start gap-2.5">
                    <i class="fa-solid fa-circle-exclamation text-sm shrink-0 mt-0.5"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <form method="post" class="space-y-4">
                <div>
                    <label for="Email" class="block text-[10px] font-bold text-slate-400 mb-1.5 uppercase tracking-wider">KULLANICI ADI VEYA E-POSTA</label>
                    <div class="relative">
                        <i class="fa-solid fa-envelope absolute top-3 left-3.5 text-slate-400 text-xs"></i>
                        <input
                            type="text"
                            id="Email"
                            name="Email"
                            value="@Model.Email"
                            placeholder="admin"
                            class="w-full pl-9 pr-3 py-2.5 border border-slate-200 rounded-xl text-xs bg-slate-50/50 text-slate-800 placeholder-slate-450 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-transparent transition"
                            required
                        />
                    </div>
                </div>

                <div>
                    <label for="Password" class="block text-[10px] font-bold text-slate-400 mb-1.5 uppercase tracking-wider">ŞİFRE</label>
                    <div class="relative">
                        <i class="fa-solid fa-key absolute top-3 left-3.5 text-slate-400 text-xs"></i>
                        <input
                            type="password"
                            id="Password"
                            name="Password"
                            placeholder="admin"
                            class="w-full pl-9 pr-3 py-2.5 border border-slate-200 rounded-xl text-xs bg-slate-50/50 text-slate-800 placeholder-slate-450 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-transparent transition"
                            required
                        />
                    </div>
                </div>

                <div class="flex items-center justify-between text-[11px] pt-1">
                    <label class="flex items-center gap-2 cursor-pointer text-slate-500">
                        <input type="checkbox" class="rounded border-slate-200 bg-slate-50 text-indigo-600 focus:ring-indigo-500 focus:ring-offset-white" />
                        <span class="select-none font-medium">Beni hatırla</span>
                    </label>
                    <a href="#" class="text-indigo-650 hover:text-indigo-750 font-semibold transition">Şifremi unuttum</a>
                </div>

                <button
                    type="submit"
                    class="flex w-full items-center justify-center gap-2 rounded-xl bg-indigo-600 hover:bg-indigo-700 py-2.5 text-xs font-semibold text-white transition-all duration-200 shadow-md shadow-indigo-600/10 active:scale-[0.99]"
                >
                    <span>Giriş Yap</span>
                    <i class="fa-solid fa-arrow-right-to-bracket text-xs"></i>
                </button>
            </form>
        </div>
    </div>
</body>
</html>
