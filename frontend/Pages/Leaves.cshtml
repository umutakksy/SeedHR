@page
@model SeedHR.Frontend.Pages.LeavesModel
@{
    ViewData["Title"] = "İzin Yönetimi";
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Employee";
    var isHrOrAdmin = userRole == "Admin" || userRole == "HR";
}

<!-- Alert banners -->
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="mb-6 p-4 rounded-2xl bg-emerald-50 border border-emerald-100 text-emerald-700 text-sm flex items-center justify-between shadow-sm" x-data="{ show: true }" x-show="show">
        <div class="flex items-center gap-3">
            <i class="fa-solid fa-circle-check text-emerald-600"></i>
            <span>@Model.SuccessMessage</span>
        </div>
        <button class="text-emerald-400 hover:text-emerald-650" @@click="show = false">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="mb-6 p-4 rounded-2xl bg-rose-50 border border-rose-100 text-rose-700 text-sm flex items-center justify-between shadow-sm" x-data="{ show: true }" x-show="show">
        <div class="flex items-center gap-3">
            <i class="fa-solid fa-circle-exclamation text-rose-600"></i>
            <span>@Model.ErrorMessage</span>
        </div>
        <button class="text-rose-400 hover:text-rose-650" @@click="show = false">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
}

<div class="space-y-6" x-data="{ showRequestModal: false, showRejectModal: false, rejectId: '', rejectionReason: '' }">

    <!-- Leave Balances Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        @if (Model.LeaveBalances == null || !Model.LeaveBalances.Any())
        {
            <div class="md:col-span-3 glass-card rounded-3xl p-6 text-center text-slate-450 text-xs">
                Kullanıcıya ait izin hakları bilgisi bulunmamaktadır.
            </div>
        }
        else
        {
            @foreach (var balance in Model.LeaveBalances)
            {
                <div class="glass-card rounded-3xl p-5 hover:border-indigo-100 transition duration-300">
                    <div class="flex items-center justify-between mb-4">
                        <span class="px-2.5 py-0.5 text-[10px] font-bold rounded bg-indigo-50 border border-indigo-100 text-indigo-655">
                            @balance.LeaveTypeName
                        </span>
                        <span class="text-xs text-slate-550 font-semibold">Yıl: @balance.Year</span>
                    </div>
                    <div class="grid grid-cols-3 gap-2 text-center">
                        <div class="p-2 bg-slate-50 border border-slate-150 rounded-2xl">
                            <p class="text-[10px] text-slate-500 font-bold">Toplam</p>
                            <p class="text-lg font-extrabold text-slate-800 mt-1">@balance.TotalDays</p>
                        </div>
                        <div class="p-2 bg-slate-50 border border-slate-150 rounded-2xl">
                            <p class="text-[10px] text-slate-500 font-bold">Kullanılan</p>
                            <p class="text-lg font-extrabold text-rose-600 mt-1">@balance.UsedDays</p>
                        </div>
                        <div class="p-2 bg-slate-50 border border-slate-150 rounded-2xl">
                            <p class="text-[10px] text-slate-500 font-bold">Kalan</p>
                            <p class="text-lg font-extrabold text-emerald-600 mt-1">@balance.RemainingDays</p>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Actions Panel -->
    <div class="flex items-center justify-between bg-white p-4 border border-slate-100 rounded-3xl shadow-sm">
        <h3 class="text-sm font-bold text-slate-850 pl-2">İzin Talepleri</h3>
        <button @@click="showRequestModal = true" 
                class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-xl shadow-md shadow-indigo-600/10 transition flex items-center justify-center gap-1.5 active:scale-[0.99]">
            <i class="fa-solid fa-plane-departure"></i> Yeni İzin Talebi
        </button>
    </div>

    <!-- Leave Requests Listing -->
    <div class="glass-card rounded-3xl overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-200/60 text-[10px] font-bold text-slate-455 uppercase bg-slate-55/20">
                        @if (isHrOrAdmin)
                        {
                            <th class="px-6 py-3.5">Çalışan</th>
                        }
                        <th class="px-6 py-3.5">İzin Türü</th>
                        <th class="px-6 py-3.5">Başlangıç - Bitiş</th>
                        <th class="px-6 py-3.5">Süre</th>
                        <th class="px-6 py-3.5">Açıklama</th>
                        <th class="px-6 py-3.5">Durum</th>
                        @if (isHrOrAdmin)
                        {
                            <th class="px-6 py-3.5 text-right">İşlemler</th>
                        }
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.LeaveRequests == null || !Model.LeaveRequests.Any())
                    {
                        <tr>
                            <td colspan="@(isHrOrAdmin ? 7 : 5)" class="px-6 py-8 text-center text-xs text-slate-450">
                                <i class="fa-solid fa-calendar-xmark text-2xl mb-2 block text-slate-300"></i>
                                Kayıtlı izin talebi bulunmamaktadır.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var request in Model.LeaveRequests)
                        {
                            <tr class="hover:bg-slate-55/50 transition duration-150">
                                @if (isHrOrAdmin)
                                {
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2.5">
                                            <div class="w-7 h-7 rounded-lg bg-indigo-50 border border-indigo-100 text-indigo-600 flex items-center justify-center font-bold text-[10px]">
                                                @(string.IsNullOrEmpty(request.UserName) ? "U" : request.UserName.Substring(0, Math.Min(2, request.UserName.Length)).ToUpper())
                                            </div>
                                            <span class="text-xs font-bold text-slate-800">@(request.UserName ?? "Bilinmeyen Kullanıcı")</span>
                                        </div>
                                    </td>
                                }
                                <td class="px-6 py-4 text-xs font-bold text-slate-700">@request.LeaveTypeName</td>
                                <td class="px-6 py-4 text-xs text-slate-500 font-semibold">@request.StartDate.ToString("dd.MM.yyyy") - @request.EndDate.ToString("dd.MM.yyyy")</td>
                                <td class="px-6 py-4 text-xs font-bold text-indigo-650">@request.DaysRequested Gün</td>
                                <td class="px-6 py-4 text-xs text-slate-550 max-w-[200px] truncate font-medium" title="@request.Reason">@request.Reason</td>
                                <td class="px-6 py-4 text-xs">
                                    @if (request.Status == "Pending")
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-amber-50 border border-amber-100 text-amber-700 text-[10px] font-semibold">
                                            Beklemede
                                        </span>
                                    }
                                    else if (request.Status == "Approved")
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-emerald-50 border border-emerald-100 text-emerald-700 text-[10px] font-semibold">
                                            Onaylandı
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-rose-50 border border-rose-100 text-rose-700 text-[10px] font-semibold" title="@request.RejectionReason">
                                            Reddedildi
                                        </span>
                                    }
                                </td>
                                @if (isHrOrAdmin)
                                {
                                    <td class="px-6 py-4 text-right">
                                        @if (request.Status == "Pending")
                                        {
                                            <div class="flex items-center justify-end gap-2">
                                                <form method="post" asp-page-handler="Approve" asp-route-id="@request.Id" class="inline">
                                                    <button type="submit" class="p-1.5 bg-emerald-50 hover:bg-emerald-600 border border-emerald-100 hover:border-transparent text-emerald-600 hover:text-white rounded-lg transition" title="Onayla">
                                                        <i class="fa-solid fa-check text-xs"></i>
                                                    </button>
                                                </form>
                                                <button @@click="rejectId = '@request.Id'; showRejectModal = true" 
                                                        class="p-1.5 bg-rose-50 hover:bg-rose-600 border border-rose-100 hover:border-transparent text-rose-600 hover:text-white rounded-lg transition" title="Reddet">
                                                    <i class="fa-solid fa-xmark text-xs"></i>
                                                </button>
                                            </div>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Request Leave Modal -->
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-955/40 backdrop-blur-[4px] p-4" 
         x-show="showRequestModal" x-transition x-cloak>
         <div class="w-full max-w-md bg-white border border-slate-150 rounded-3xl p-6 text-left shadow-2xl">
            <div class="flex items-center justify-between mb-4 pb-2 border-b border-slate-100">
                <h3 class="text-sm font-bold text-slate-855">İzin Talebi Oluştur</h3>
                <button class="text-slate-400 hover:text-slate-655" @@click="showRequestModal = false">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <form method="post" asp-page-handler="Create" class="space-y-4">
                <div>
                    <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">İzin Türü</label>
                    <select asp-for="NewLeave.LeaveTypeId" required 
                            class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition">
                        <option value="">İzin Türü Seçin</option>
                        @foreach (var type in Model.LeaveTypes)
                        {
                            <option value="@type.Id">@type.Name (@type.DefaultDays Gün)</option>
                        }
                    </select>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Başlangıç Tarihi</label>
                        <input type="date" asp-for="NewLeave.StartDate" required 
                               class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-850 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Bitiş Tarihi</label>
                        <input type="date" asp-for="NewLeave.EndDate" required 
                               class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-855 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition" />
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Açıklama / Gerekçe</label>
                    <textarea asp-for="NewLeave.Reason" required rows="3" placeholder="İzin gerekçesini kısaca yazın..." 
                              class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-850 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition"></textarea>
                </div>

                <div class="pt-4 flex items-center justify-end gap-2 border-t border-slate-100">
                    <button type="button" class="px-4 py-2 border border-slate-200 hover:bg-slate-55 text-slate-500 text-xs font-bold rounded-xl transition"
                            @@click="showRequestModal = false">İptal</button>
                    <button type="submit" class="px-5 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-xl shadow transition active:scale-[0.99]">Gönder</button>
                </div>
            </form>
         </div>
    </div>

    <!-- Reject Leave Modal -->
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-955/40 backdrop-blur-[4px] p-4" 
         x-show="showRejectModal" x-transition x-cloak>
         <div class="w-full max-w-sm bg-white border border-slate-150 rounded-3xl p-6 text-left shadow-2xl">
            <div class="flex items-center justify-between mb-4 pb-2 border-b border-slate-100">
                <h3 class="text-sm font-bold text-slate-855">İzin Talebi Red Gerekçesi</h3>
                <button class="text-slate-400 hover:text-slate-655" @@click="showRejectModal = false">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <form method="post" asp-page-handler="Reject" class="space-y-4">
                <input type="hidden" name="id" x-model="rejectId" />

                <div>
                    <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Reddetme Nedeni</label>
                    <textarea name="rejectionReason" required rows="3" placeholder="Red gerekçesini belirtin..." 
                              class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-850 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition"></textarea>
                </div>

                <div class="pt-4 flex items-center justify-end gap-2 border-t border-slate-100">
                    <button type="button" class="px-4 py-2 border border-slate-200 hover:bg-slate-55 text-slate-500 text-xs font-bold rounded-xl transition"
                            @@click="showRejectModal = false">İptal</button>
                    <button type="submit" class="px-5 py-2 bg-rose-600 hover:bg-rose-700 text-white text-xs font-bold rounded-xl shadow transition active:scale-[0.99]">Talebi Reddet</button>
                </div>
            </form>
         </div>
    </div>

</div>
