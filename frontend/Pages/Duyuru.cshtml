@page "/duyuru"
@model SeedHR.Frontend.Pages.DuyuruModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Duyurular & Bilgi Panosu - SeedHR</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                        outfit: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f0f5ff',
                            100: '#e0ebff',
                            200: '#c2d7ff',
                            300: '#94b8ff',
                            400: '#5e8eff',
                            500: '#3b66f5',
                            600: '#2546eb',
                            700: '#1d33d9',
                            800: '#1c2bb0',
                            900: '#1d2a8c',
                            950: '#121754',
                        }
                    },
                    animation: {
                        'spin-slow': 'spin 12s linear infinite',
                        'bounce-slow': 'bounce 3s infinite',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.6);
        }
        .gradient-bg {
            background: radial-gradient(circle at 10% 20%, rgba(59, 102, 245, 0.08) 0%, transparent 40%),
                        radial-gradient(circle at 90% 80%, rgba(94, 142, 255, 0.06) 0%, transparent 50%);
        }
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="gradient-bg min-h-screen text-slate-800 antialiased flex flex-col justify-between">

    <!-- Header Section -->
    <header class="w-full py-5 px-4 md:px-8 max-w-7xl mx-auto">
        <div class="glass-card rounded-2xl shadow-sm border border-slate-100 p-4 md:p-6 flex flex-col md:flex-row justify-between items-center gap-4">
            <!-- Brand Logo -->
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-brand-500 to-indigo-600 flex items-center justify-center text-white shadow-md shadow-brand-500/20">
                    <i class="fa-solid fa-seedling text-lg"></i>
                </div>
                <div>
                    <h1 class="text-xl font-bold font-outfit tracking-tight text-slate-900">Seed<span class="text-brand-500">HR</span></h1>
                    <p class="text-xs text-slate-500 font-medium">Duyuru &amp; Bilgi Panosu</p>
                </div>
            </div>

            <!-- Date & Info Display -->
            <div class="flex flex-wrap items-center justify-center gap-6">
                <!-- Date -->
                <div class="flex items-center gap-3 text-sm text-slate-700 bg-slate-100/50 py-2 px-4 rounded-xl border border-slate-200/40">
                    <i class="fa-regular fa-calendar-days text-brand-500 text-lg"></i>
                    <span class="font-semibold text-slate-700">@Model.BugununTarihi</span>
                </div>

                <!-- Weather -->
                <div class="flex items-center gap-3 text-sm bg-slate-100/50 py-2 px-4 rounded-xl border border-slate-200/40">
                    <i class="fa-solid @Model.HavaIcon text-lg"></i>
                    <div class="flex flex-col">
                        <span class="font-bold text-slate-800 leading-none">@Model.HavaDerece</span>
                        <span class="text-[10px] text-slate-500 font-medium mt-0.5">@Model.HavaDurumu</span>
                    </div>
                </div>

                <!-- Careers Page Shortcut -->
                <a href="/Basvuru" class="bg-brand-50 hover:bg-brand-100 text-brand-600 text-xs font-bold py-2.5 px-4 rounded-xl border border-brand-100 transition-all flex items-center gap-2">
                    <i class="fa-solid fa-briefcase"></i>
                    Kariyer Fırsatları
                </a>
            </div>
        </div>
    </header>

    <!-- Main Section -->
    <main class="w-full flex-grow px-4 md:px-8 max-w-7xl mx-auto py-4">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Left & Center Area: Announcements -->
            <div class="lg:col-span-2 space-y-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2 font-outfit">
                        <i class="fa-solid fa-bullhorn text-brand-500"></i>
                        Güncel Duyurular
                    </h2>
                    <span class="text-xs font-semibold bg-brand-50 text-brand-600 py-1 px-2.5 rounded-full">
                        @Model.Announcements.Count Aktif Duyuru
                    </span>
                </div>

                @if (!Model.Announcements.Any())
                {
                    <div class="glass-card rounded-2xl p-12 text-center border border-slate-100 flex flex-col items-center justify-center">
                        <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 mb-4">
                            <i class="fa-solid fa-folder-open text-2xl"></i>
                        </div>
                        <h3 class="text-base font-bold text-slate-700">Yayınlanmış Duyuru Bulunmuyor</h3>
                        <p class="text-xs text-slate-500 mt-1 max-w-xs">Şu anda panoda aktif duyuru bulunmamaktadır. Güncellemeler için takipte kalın.</p>
                    </div>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var announcement in Model.Announcements)
                        {
                            <article class="glass-card rounded-2xl p-5 md:p-6 shadow-sm hover:shadow-md transition-all duration-300 border border-slate-100/80 hover:-translate-y-0.5 group">
                                <div class="flex items-start justify-between gap-4 flex-wrap sm:flex-nowrap">
                                    <div class="space-y-2">
                                        <!-- Header line -->
                                        <div class="flex items-center gap-3">
                                            <span class="text-[10px] font-bold tracking-wider uppercase bg-brand-50 text-brand-600 px-2 py-0.5 rounded-md">
                                                @(announcement.Category == "Genel" ? "Genel Duyuru" :
                                                  announcement.Category == "Etkinlik" ? "Şirket İçi Etkinlik" :
                                                  announcement.Category == "İzin" ? "Resmi Tatil / İzin" :
                                                  announcement.Category == "IK" ? "İK Güncellemesi" :
                                                  announcement.Category == "YemekMenusu" ? "Yemek Menüsü" :
                                                  announcement.Category)
                                            </span>
                                            <span class="text-[11px] font-medium text-slate-400 flex items-center gap-1.5">
                                                <i class="fa-regular fa-clock"></i>
                                                @announcement.PublishedDate.ToString("dd MMMM yyyy")
                                            </span>
                                        </div>
                                        <!-- Title -->
                                        <h3 class="text-base md:text-lg font-bold text-slate-800 group-hover:text-brand-500 transition-colors">
                                            @announcement.Title
                                        </h3>
                                    </div>
                                    
                                    <!-- Publisher Initial -->
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 rounded-lg bg-indigo-50 border border-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-xs">
                                            @(!string.IsNullOrEmpty(announcement.CreatedBy) ? announcement.CreatedBy.Substring(0, Math.Min(2, announcement.CreatedBy.Length)).ToUpper() : "ST")
                                        </div>
                                        <div class="hidden sm:block">
                                            <p class="text-[10px] text-slate-400 font-semibold leading-none">Yayınlayan</p>
                                            <p class="text-xs font-bold text-slate-600">@announcement.CreatedBy</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Content -->
                                <p class="text-xs md:text-sm text-slate-600 leading-relaxed font-medium mt-4 whitespace-pre-wrap">
                                    @announcement.Content
                                </p>
                            </article>
                        }
                    </div>
                }
            </div>

            <!-- Right Area: Info Cards -->
            <div class="space-y-6">
                <!-- Günün Menüsü Card -->
                <section class="glass-card rounded-2xl shadow-sm border border-slate-100 overflow-hidden relative group">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-brand-500/5 rounded-full -mr-8 -mt-8 transition-transform duration-500 group-hover:scale-110"></div>
                    
                    <div class="p-6 relative">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-base font-bold text-slate-900 flex items-center gap-2 font-outfit">
                                <i class="fa-solid fa-utensils text-brand-500"></i>
                                Günün Yemek Menüsü
                            </h2>
                            <span class="text-[10px] font-bold text-brand-500 bg-brand-50 py-0.5 px-2 rounded-md">Öğle Yemeği</span>
                        </div>

                        <div class="space-y-3 mt-4">
                            @if (Model.GununMenusu != null && Model.GununMenusu.Any())
                            {
                                @for (int i = 0; i < Model.GununMenusu.Count; i++)
                                {
                                    var item = Model.GununMenusu[i];
                                    string icon = "fa-bowl-food";
                                    if (item.Contains("Çorba")) icon = "fa-bowl-hot";
                                    else if (item.Contains("Beğendi") || item.Contains("Tavuk") || item.Contains("Fasulye") || item.Contains("Köfte") || item.Contains("Stroganoff") || item.Contains("Tabağı")) icon = "fa-plate-wheat";
                                    else if (item.Contains("Pilavı") || item.Contains("Erişte") || item.Contains("Makarna")) icon = "fa-spoon";
                                    else if (item.Contains("Salatası") || item.Contains("Cacık") || item.Contains("Turşu")) icon = "fa-leaf";
                                    else if (item.Contains("Tatlısı") || item.Contains("Meyve") || item.Contains("Revani") || item.Contains("Sütlaç") || item.Contains("Puding") || item.Contains("Dondurma")) icon = "fa-cookie-bite";

                                    <div class="flex items-center gap-3.5 py-2.5 px-3.5 rounded-xl bg-slate-50 border border-slate-100 transition-colors hover:bg-white hover:border-slate-200/80">
                                        <div class="w-8 h-8 rounded-lg bg-brand-50 text-brand-500 flex items-center justify-center shadow-sm">
                                            <i class="fa-solid @icon text-xs"></i>
                                        </div>
                                        <span class="text-xs font-bold text-slate-700">@item</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-xs text-slate-500 text-center py-4">Menü bilgisi bulunamadı.</p>
                            }
                        </div>
                    </div>
                </section>

                <!-- Information Board / Quick Stats Card -->
                <section class="glass-card rounded-2xl shadow-sm border border-slate-100 p-6 relative overflow-hidden">
                    <div class="absolute -bottom-8 -left-8 w-24 h-24 bg-brand-500/5 rounded-full"></div>
                    
                    <h2 class="text-base font-bold text-slate-900 flex items-center gap-2 mb-4 font-outfit">
                        <i class="fa-solid fa-circle-info text-brand-500"></i>
                        Faydalı Bilgiler &amp; İletişim
                    </h2>
                    
                    <div class="space-y-4">
                        <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
                            <h4 class="text-xs font-bold text-slate-800 flex items-center gap-1.5">
                                <i class="fa-solid fa-clock-rotate-left text-brand-500"></i>
                                Mesai Saatleri
                            </h4>
                            <p class="text-[11px] text-slate-500 font-medium mt-1">Hafta içi her gün: 08:30 - 18:00 saatleri arasındadır. Hafta sonları kapalıyız.</p>
                        </div>

                        <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
                            <h4 class="text-xs font-bold text-slate-800 flex items-center gap-1.5">
                                <i class="fa-solid fa-envelope text-brand-500"></i>
                                İK Destek
                            </h4>
                            <p class="text-[11px] text-slate-500 font-medium mt-1">Soru, talep ve geri bildirimleriniz için <a href="mailto:ik@seedhr.com.tr" class="text-brand-600 font-bold hover:underline">ik@seedhr.com.tr</a> adresinden bize ulaşabilirsiniz.</p>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="w-full py-6 mt-8 border-t border-slate-200/50 bg-white/40">
        <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-slate-500 font-medium">
            <p>&copy; @DateTime.UtcNow.AddHours(3).Year SeedHR. Tüm Hakları Saklıdır.</p>
            <div class="flex items-center gap-4">
                <a href="/Login" class="hover:text-brand-500 transition-colors font-bold">Yönetim Paneli Girişi</a>
                <span>&bull;</span>
                <a href="/Basvuru" class="hover:text-brand-500 transition-colors font-bold">Kariyer</a>
            </div>
        </div>
    </footer>

</body>
</html>
