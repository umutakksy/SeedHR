@page
@model SeedHR.Frontend.Pages.AttendanceModel
@{
    ViewData["Title"] = "Çalışma Saatleri & Takvim";
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Employee";
    var isHrOrAdmin = userRole == "Admin" || userRole == "HR";
}

<!-- Alert banners -->
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="mb-6 p-4 rounded-2xl bg-emerald-50 border border-emerald-100 text-emerald-700 text-sm flex items-center justify-between shadow-sm" x-data="{ show: true }" x-show="show">
        <div class="flex items-center gap-3">
            <i class="fa-solid fa-circle-check text-emerald-600"></i>
            <span>@Model.SuccessMessage</span>
        </div>
        <button class="text-emerald-400 hover:text-emerald-650" @@click="show = false">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="mb-6 p-4 rounded-2xl bg-rose-50 border border-rose-100 text-rose-700 text-sm flex items-center justify-between shadow-sm" x-data="{ show: true }" x-show="show">
        <div class="flex items-center gap-3">
            <i class="fa-solid fa-circle-exclamation text-rose-600"></i>
            <span>@Model.ErrorMessage</span>
        </div>
        <button class="text-rose-400 hover:text-rose-650" @@click="show = false">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
}

<div class="space-y-6" x-data="{ 
    activeTab: 'logs', 
    showAddScheduleModal: false, 
    showEditScheduleModal: false,
    editSchedId: '',
    editSchedDate: '',
    editSchedType: '',
    editSchedDesc: '',
    
    openEdit(sched) {
        this.editSchedId = sched.id;
        this.editSchedDate = sched.date.substring(0, 10);
        this.editSchedType = sched.type;
        this.editSchedDesc = sched.description || '';
        this.showEditScheduleModal = true;
    }
}">

    <!-- Tab Switcher and Controls -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 bg-white p-4 border border-slate-100 rounded-3xl shadow-sm">
        <div class="flex p-1 bg-slate-50 rounded-2xl border border-slate-200/50 w-full sm:w-auto">
            <button @@click="activeTab = 'logs'" 
                    :class="activeTab === 'logs' ? 'bg-indigo-600 text-white font-bold shadow-sm' : 'text-slate-500 hover:text-slate-800'" 
                    class="flex-1 sm:flex-initial px-6 py-2 rounded-xl text-xs transition duration-150 flex items-center justify-center gap-2 font-semibold">
                <i class="fa-solid fa-list-check"></i> Katılım Kayıtları
            </button>
            <button @@click="activeTab = 'schedules'" 
                    :class="activeTab === 'schedules' ? 'bg-indigo-600 text-white font-bold shadow-sm' : 'text-slate-500 hover:text-slate-800'" 
                    class="flex-1 sm:flex-initial px-6 py-2 rounded-xl text-xs transition duration-150 flex items-center justify-center gap-2 font-semibold">
                <i class="fa-solid fa-calendar-days"></i> Vardiya Takvimi
            </button>
        </div>

        <!-- Right Side Controls depending on active tab -->
        <div x-show="activeTab === 'schedules' && @(isHrOrAdmin ? "true" : "false")" class="w-full sm:w-auto text-right">
            <button @@click="showAddScheduleModal = true" 
                    class="w-full sm:w-auto px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-xl shadow-md shadow-indigo-600/10 transition flex items-center justify-center gap-1.5 active:scale-[0.99]">
                <i class="fa-solid fa-calendar-plus"></i> Yeni Vardiya / İzin Günü Ekle
            </button>
        </div>
    </div>

    <!-- Tab 1: Katılım Kayıtları (Attendance Logs) -->
    <div x-show="activeTab === 'logs'" x-transition class="glass-card rounded-3xl overflow-hidden shadow-sm">
        <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
            <h3 class="text-sm font-bold text-slate-850">Giriş / Çıkış Log Listesi</h3>
            <span class="text-[10px] text-slate-500 font-bold">Son kayıtlar</span>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-200/60 text-[10px] font-bold text-slate-455 uppercase bg-slate-55/20">
                        @if (isHrOrAdmin)
                        {
                            <th class="px-6 py-3.5">Çalışan</th>
                        }
                        <th class="px-6 py-3.5">Tarih</th>
                        <th class="px-6 py-3.5">Giriş Saati</th>
                        <th class="px-6 py-3.5">Çıkış Saati</th>
                        <th class="px-6 py-3.5">Çalışılan Süre</th>
                        <th class="px-6 py-3.5">Durum</th>
                        <th class="px-6 py-3.5">Notlar</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.AttendanceRecords == null || !Model.AttendanceRecords.Any())
                    {
                        <tr>
                            <td colspan="@(isHrOrAdmin ? 7 : 6)" class="px-6 py-8 text-center text-xs text-slate-450">
                                <i class="fa-solid fa-clock-rotate-left text-2xl mb-2 block text-slate-350"></i>
                                Katılım kaydı bulunamadı.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var rec in Model.AttendanceRecords)
                        {
                            <tr class="hover:bg-slate-55/50 transition duration-150">
                                @if (isHrOrAdmin)
                                {
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2.5">
                                            <div class="w-7 h-7 rounded-lg bg-indigo-50 border border-indigo-100 text-indigo-600 flex items-center justify-center font-bold text-[10px]">
                                                @(string.IsNullOrEmpty(rec.UserName) ? "U" : rec.UserName.Substring(0, Math.Min(2, rec.UserName.Length)).ToUpper())
                                            </div>
                                            <span class="text-xs font-bold text-slate-800">@(rec.UserName ?? "Bilinmeyen Kullanıcı")</span>
                                        </div>
                                    </td>
                                }
                                <td class="px-6 py-4 text-xs font-bold text-slate-700">@rec.Date</td>
                                <td class="px-6 py-4 text-xs text-slate-600 font-semibold">
                                    <span class="inline-flex items-center gap-1.5">
                                        <i class="fa-solid fa-right-to-bracket text-emerald-600"></i> @(rec.CheckIn ?? "--:--")
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-xs text-slate-600 font-semibold">
                                    <span class="inline-flex items-center gap-1.5">
                                        <i class="fa-solid fa-right-from-bracket text-rose-600"></i> @(rec.CheckOut ?? "--:--")
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-xs font-bold text-indigo-650">@(rec.TotalHoursWorked?.ToString("0.0") ?? "0") Saat</td>
                                <td class="px-6 py-4 text-xs">
                                    @if (rec.Status == "Present")
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-emerald-50 border border-emerald-100 text-emerald-700 text-[10px] font-semibold">
                                            Mevcut
                                        </span>
                                    }
                                    else if (rec.Status == "Late")
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-amber-50 border border-amber-100 text-amber-700 text-[10px] font-semibold">
                                            Geç Kaldı
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-slate-100 border border-slate-200 text-slate-600 text-[10px] font-semibold">
                                            @rec.Status
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-xs text-slate-550 truncate max-w-[150px] font-medium" title="@rec.Notes">@rec.Notes</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Tab 2: Vardiya Takvimi (Work Schedule Timeline) -->
    <div x-show="activeTab === 'schedules'" x-transition class="space-y-4">
        <div class="glass-card rounded-3xl p-6 shadow-sm">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-6">
                <h3 class="text-sm font-bold text-slate-855">Planlanmış Vardiyalar & Çalışma Takvimi</h3>
                <span class="text-[10px] text-indigo-655 font-bold"><i class="fa-solid fa-circle-info mr-1"></i> Son 30 günlük planlamalar gösterilmektedir.</span>
            </div>

            @if (Model.WorkSchedules == null || !Model.WorkSchedules.Any())
            {
                <div class="p-8 text-center text-slate-450 text-xs">
                    <i class="fa-solid fa-calendar-xmark text-2xl mb-2 block text-slate-300"></i>
                    Takvimde kayıtlı vardiya veya izin günü planı bulunmamaktadır.
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var sched in Model.WorkSchedules.OrderBy(s => s.Date))
                    {
                        <div class="p-4 bg-slate-50 border border-slate-150 rounded-2xl flex items-start justify-between gap-3 hover:border-indigo-100 transition">
                            <div class="space-y-2 text-left">
                                <div class="flex items-center gap-2">
                                    <span class="px-2 py-0.5 text-[9px] font-extrabold rounded @(sched.Type == "Holiday" ? "bg-red-50 border border-red-100 text-red-600" : sched.Type == "Off" ? "bg-slate-100 border border-slate-200 text-slate-650" : "bg-indigo-50 border border-indigo-100 text-indigo-655")">
                                        @sched.Type
                                    </span>
                                    <span class="text-[10px] text-slate-500 font-semibold">@sched.Date.ToString("dddd")</span>
                                </div>
                                <h4 class="text-xs font-bold text-slate-800">@sched.Date.ToString("dd MMMM yyyy")</h4>
                                <p class="text-[11px] text-slate-550 font-medium">@sched.Description</p>
                            </div>
                            @if (isHrOrAdmin)
                            {
                                <div class="flex items-center gap-1.5 shrink-0">
                                    <button @@click="openEdit({
                                        id: '@sched.Id',
                                        date: '@sched.Date.ToString("yyyy-MM-dd")',
                                        type: '@sched.Type',
                                        description: '@sched.Description'
                                    })" class="p-1 text-slate-400 hover:text-amber-600 transition" title="Düzenle">
                                        <i class="fa-solid fa-pen text-[11px]"></i>
                                    </button>
                                    <form method="post" asp-page-handler="DeleteSchedule" asp-route-id="@sched.Id" class="inline" onsubmit="return confirm('Bu vardiyayı takvimden silmek istediğinize emin misiniz?')">
                                        <button type="submit" class="p-1 text-slate-400 hover:text-rose-600 transition" title="Sil">
                                            <i class="fa-solid fa-trash-can text-[11px]"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Create Schedule Modal -->
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-955/40 backdrop-blur-[4px] p-4" 
         x-show="showAddScheduleModal" x-transition x-cloak>
         <div class="w-full max-w-sm bg-white border border-slate-150 rounded-3xl p-6 text-left shadow-2xl">
            <div class="flex items-center justify-between mb-4 pb-2 border-b border-slate-100">
                <h3 class="text-sm font-bold text-slate-850">Vardiya / Çalışma Günü Tanımla</h3>
                <button class="text-slate-400 hover:text-slate-655" @@click="showAddScheduleModal = false">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <form method="post" asp-page-handler="CreateSchedule" class="space-y-4">
                <div>
                    <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Tarih</label>
                    <input type="date" asp-for="NewSchedule.Date" required 
                           class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-850 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition" />
                </div>

                <div>
                    <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Çalışma Türü</label>
                    <select asp-for="NewSchedule.Type" required 
                            class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition">
                        <option value="Work">Normal Çalışma Günü</option>
                        <option value="Holiday">Resmi Tatil / Bayram</option>
                        <option value="Off">Haftalık İzin / Tatil</option>
                    </select>
                </div>

                <div>
                    <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Açıklama</label>
                    <textarea asp-for="NewSchedule.Description" required rows="2" placeholder="Örn: 09:00 - 18:00 Standard Mesai" 
                              class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-850 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition"></textarea>
                </div>

                <div class="pt-4 flex items-center justify-end gap-2 border-t border-slate-100">
                    <button type="button" class="px-4 py-2 border border-slate-200 hover:bg-slate-55 text-slate-500 text-xs font-bold rounded-xl transition"
                            @@click="showAddScheduleModal = false">İptal</button>
                    <button type="submit" class="px-5 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-xl shadow transition active:scale-[0.99]">Ekle</button>
                </div>
            </form>
         </div>
    </div>

    <!-- Edit Schedule Modal -->
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-955/40 backdrop-blur-[4px] p-4" 
         x-show="showEditScheduleModal" x-transition x-cloak>
         <div class="w-full max-w-sm bg-white border border-slate-150 rounded-3xl p-6 text-left shadow-2xl">
            <div class="flex items-center justify-between mb-4 pb-2 border-b border-slate-100">
                <h3 class="text-sm font-bold text-slate-855">Vardiya Bilgisini Düzenle</h3>
                <button class="text-slate-400 hover:text-slate-655" @@click="showEditScheduleModal = false">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <form method="post" asp-page-handler="UpdateSchedule" class="space-y-4">
                <input type="hidden" name="EditScheduleId" x-model="editSchedId" />

                <div>
                    <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Tarih</label>
                    <input type="date" name="NewSchedule.Date" x-model="editSchedDate" required 
                           class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-850 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition" />
                </div>

                <div>
                    <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Çalışma Türü</label>
                    <select name="NewSchedule.Type" x-model="editSchedType" required 
                            class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-850 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition">
                        <option value="Work">Normal Çalışma Günü</option>
                        <option value="Holiday">Resmi Tatil / Bayram</option>
                        <option value="Off">Haftalık İzin / Tatil</option>
                    </select>
                </div>

                <div>
                    <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Açıklama</label>
                    <textarea name="NewSchedule.Description" x-model="editSchedDesc" required rows="2" 
                              class="w-full bg-slate-50 border border-slate-200 rounded-xl py-2.5 px-3 text-xs text-slate-850 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition"></textarea>
                </div>

                <div class="pt-4 flex items-center justify-end gap-2 border-t border-slate-100">
                    <button type="button" class="px-4 py-2 border border-slate-200 hover:bg-slate-55 text-slate-500 text-xs font-bold rounded-xl transition"
                            @@click="showEditScheduleModal = false">İptal</button>
                    <button type="submit" class="px-5 py-2 bg-amber-600 hover:bg-amber-700 text-white text-xs font-bold rounded-xl shadow transition active:scale-[0.99]">Güncelle</button>
                </div>
            </form>
         </div>
    </div>

</div>
