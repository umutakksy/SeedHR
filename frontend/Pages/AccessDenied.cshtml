@page
@model SeedHR.Frontend.Pages.AccessDeniedModel
@{
    ViewData["Title"] = "Yetkisiz Erişim";
}

<div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6">
    <div class="w-20 h-20 rounded-3xl bg-rose-600/10 border border-rose-500/25 text-rose-500 flex items-center justify-center text-3xl shadow-lg shadow-rose-950/20 mb-6">
        <i class="fa-solid fa-shield-halved"></i>
    </div>
    
    <h1 class="text-2xl font-extrabold text-white">Erişim Engellendi</h1>
    <p class="text-sm text-slate-400 mt-2 max-w-md">
        Bu sayfayı görüntülemek veya bu işlemi gerçekleştirmek için gerekli yetki haklarına sahip değilsiniz.
    </p>

    <div class="mt-8 flex items-center gap-4">
        <a href="/" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-bold rounded-xl shadow-lg shadow-indigo-600/25 transition">
            Gösterge Paneline Dön
        </a>
        <a href="/Logout" class="px-5 py-2.5 border border-slate-800 hover:bg-slate-900 text-slate-300 hover:text-white text-xs font-bold rounded-xl transition">
            Farklı Hesapla Giriş Yap
        </a>
    </div>
</div>
